run = "npm install && npx prisma generate && npx prisma db push && npm run build && npm start"
entrypoint = "server/index.js"
modules = ["nodejs-20"]

[nix]
channel = "stable-24_05"

[deployment]
build = ["sh", "-c", "npm install && npx prisma generate && npx prisma db push && npm run build"]
run = ["sh", "-c", "npm start"]
deploymentTarget = "cloudrun"

[env]
DATABASE_URL = "file:./dev.db"
PORT = "5000"
NODE_ENV = "production"

[[ports]]
localPort = 5000
externalPort = 80
