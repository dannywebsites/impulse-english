---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HijoNoAvanzaInglesPage, { articleSchema, faqItems } from '../../../pages/blog/HijoNoAvanzaInglesPage';
import CookieBanner from '../../../components/CookieBanner';
import { generateFAQSchema } from '../../../utils/schemaData';

const schemas = [
  articleSchema,
  ...(faqItems?.length > 0 ? [generateFAQSchema(faqItems)] : []),
];
---

<BaseLayout
  title="Mi Hijo No Avanza en Inglés"
  description="Si tu hijo no avanza en inglés puede ser por método inadecuado, falta de exposición o desmotivación. Descubre 7 causas y soluciones para cada una."
  canonical="/blog/hijo-no-avanza-ingles"
  ogType="article"
  schemas={schemas}
>
  <HijoNoAvanzaInglesPage client:load />
  <CookieBanner client:idle />
</BaseLayout>
