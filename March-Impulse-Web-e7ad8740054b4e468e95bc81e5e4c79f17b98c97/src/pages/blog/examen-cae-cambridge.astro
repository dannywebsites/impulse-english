---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ExamenCaeCambridgePage, { articleSchema, faqs } from '../../../pages/blog/ExamenCaeCambridgePage';
import CookieBanner from '../../../components/CookieBanner';
import { generateFAQSchema } from '../../../utils/schemaData';

const schemas = [
  articleSchema,
  ...(faqs?.length > 0 ? [generateFAQSchema(faqs)] : []),
];
---

<BaseLayout
  title="Examen C1 Advanced (CAE) Cambridge: Todo lo que Necesitas Saber [2026]"
  description="Guía completa del examen CAE (C1 Advanced) de Cambridge: partes del examen, duración, puntuaciones, precio en Madrid y claves para aprobar en 2026."
  fullTitle={true}
  canonical="/blog/examen-cae-cambridge"
  ogType="article"
  schemas={schemas}
>
  <ExamenCaeCambridgePage client:idle />
  <CookieBanner client:idle />
</BaseLayout>
