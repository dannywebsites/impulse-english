---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PrecioB1CambridgePage, { articleSchema, faqItems } from '../../../pages/blog/PrecioB1CambridgePage';
import CookieBanner from '../../../components/CookieBanner';
import { generateFAQSchema } from '../../../utils/schemaData';

const schemas = [
  articleSchema,
  ...(faqItems?.length > 0 ? [generateFAQSchema(faqItems)] : []),
];
---

<BaseLayout
