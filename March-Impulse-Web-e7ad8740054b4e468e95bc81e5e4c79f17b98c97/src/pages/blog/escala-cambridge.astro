---
import BaseLayout from '../../layouts/BaseLayout.astro';
import EscalaCambridgePage, { articleSchema, faqs } from '../../../pages/blog/EscalaCambridgePage';
import CookieBanner from '../../../components/CookieBanner';
import { generateFAQSchema } from '../../../utils/schemaData';

const schemas = [
  articleSchema,
  ...(faqs?.length > 0 ? [generateFAQSchema(faqs)] : []),
];
---

<BaseLayout
  title="Escala Cambridge: Puntuaciones, Niveles y Equivalencias [Guía 2026]"
  description="¿Qué puntuación necesitas en los exámenes Cambridge? Descubre la escala oficial, equivalencias entre niveles A2–C2 y cómo se calcula tu nota. Tabla actualizada 2026."
  fullTitle={true}
  canonical="/blog/escala-cambridge"
  ogType="article"
  schemas={schemas}
>
  <EscalaCambridgePage client:idle />
  <CookieBanner client:idle />
</BaseLayout>
