---
import BaseLayout from '../../layouts/BaseLayout.astro';
import EscalaCambridgePage, { articleSchema, faqs } from '../../../pages/blog/EscalaCambridgePage';
import CookieBanner from '../../../components/CookieBanner';
import { generateFAQSchema } from '../../../utils/schemaData';

const schemas = [
  articleSchema,
  ...(faqs?.length > 0 ? [generateFAQSchema(faqs)] : []),
];
---

<BaseLayout
  title="Escala Cambridge Explicada"
  description="Entiende la Cambridge English Scale: niveles A1-C2, puntuaciones, Grades A/B/C, equivalencias MCER y cómo interpretar tus resultados en exámenes Cambridge."
  canonical="/blog/escala-cambridge"
  ogType="article"
  schemas={schemas}
>
  <EscalaCambridgePage client:idle />
  <CookieBanner client:idle />
</BaseLayout>
