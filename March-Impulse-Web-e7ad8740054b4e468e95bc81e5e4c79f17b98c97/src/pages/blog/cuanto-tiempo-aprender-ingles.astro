---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CuantoTiempoAprenderInglesPage, { articleSchema, faqItems } from '../../../pages/blog/CuantoTiempoAprenderInglesPage';
import CookieBanner from '../../../components/CookieBanner';
import { generateFAQSchema } from '../../../utils/schemaData';

const schemas = [
  articleSchema,
  ...(faqItems?.length > 0 ? [generateFAQSchema(faqItems)] : []),
];
---

<BaseLayout
  title="¿Cuánto Tiempo Se Tarda en Aprender Inglés? Plazos Realistas por Nivel [2026]"
  description="¿Cuánto tiempo necesitas para aprender inglés? Plazos realistas por nivel (A1–C2), horas según Cambridge y el MCER, y consejos para acelerar tu progreso."
  fullTitle={true}
  canonical="/blog/cuanto-tiempo-aprender-ingles"
  ogType="article"
  schemas={schemas}
>
  <CuantoTiempoAprenderInglesPage client:idle />
  <CookieBanner client:idle />
</BaseLayout>
