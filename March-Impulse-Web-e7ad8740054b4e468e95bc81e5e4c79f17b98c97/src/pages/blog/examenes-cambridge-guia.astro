---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ExamenesCambridgeGuiaPage, { articleSchema, faqItems } from '../../../pages/blog/ExamenesCambridgeGuiaPage';
import CookieBanner from '../../../components/CookieBanner';
import { generateFAQSchema } from '../../../utils/schemaData';

const schemas = [
  articleSchema,
  ...(faqItems?.length > 0 ? [generateFAQSchema(faqItems)] : []),
];
---

<BaseLayout
  title="Guía Exámenes Cambridge"
  description="Descubre todo sobre los exámenes Cambridge: niveles del A1 al C2, estructura detallada, preparación efectiva y recursos oficiales. Guía actualizada 2026 con estrategias probadas y consejos de expertos."
  canonical="/blog/examenes-cambridge-guia"
  ogType="article"
  schemas={schemas}
>
  <ExamenesCambridgeGuiaPage client:load />
  <CookieBanner client:idle />
</BaseLayout>
