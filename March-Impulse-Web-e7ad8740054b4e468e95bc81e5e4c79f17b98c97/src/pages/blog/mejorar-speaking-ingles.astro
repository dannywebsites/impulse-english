---
import BaseLayout from '../../layouts/BaseLayout.astro';
import MejorarSpeakingInglesPage, { articleSchema, faqItems } from '../../../pages/blog/MejorarSpeakingInglesPage';
import CookieBanner from '../../../components/CookieBanner';
import { generateFAQSchema } from '../../../utils/schemaData';

const schemas = [
  articleSchema,
  ...(faqItems?.length > 0 ? [generateFAQSchema(faqItems)] : []),
];
---

<BaseLayout
  title="Mejorar Speaking en Inglés"
  description="Mejora tu speaking en inglés: técnicas de fluidez, pronunciación y confianza. Ejercicios prácticos para hacer solo o en grupo con resultados en 4 semanas."
  canonical="/blog/mejorar-speaking-ingles"
  ogType="article"
  schemas={schemas}
>
  <MejorarSpeakingInglesPage client:idle />
  <CookieBanner client:idle />
</BaseLayout>
