---
import BaseLayout from '../../layouts/BaseLayout.astro';
import EsDificilB2FirstPage, { articleSchema, faqItems } from '../../../pages/blog/EsDificilB2FirstPage';
import CookieBanner from '../../../components/CookieBanner';
import { generateFAQSchema } from '../../../utils/schemaData';

const schemas = [
  articleSchema,
  ...(faqItems?.length > 0 ? [generateFAQSchema(faqItems)] : []),
];
---

<BaseLayout
  title="¿Es Difícil el B2 First de Cambridge? Nivel Real y Consejos para Aprobar [2026]"
  description="¿Es difícil aprobar el B2 First? Te contamos el nivel real que necesitas, la tasa de aprobados, las partes más difíciles y 6 consejos de profesores nativos."
  fullTitle={true}
  canonical="/blog/es-dificil-b2-first"
  ogType="article"
  schemas={schemas}
>
  <EsDificilB2FirstPage client:idle />
  <CookieBanner client:idle />
</BaseLayout>
