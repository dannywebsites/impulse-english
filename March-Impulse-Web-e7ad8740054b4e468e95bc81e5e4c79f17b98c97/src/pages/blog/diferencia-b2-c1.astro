---
import BaseLayout from '../../layouts/BaseLayout.astro';
import DiferenciaB2C1Page, { articleSchema, faqItems } from '../../../pages/blog/DiferenciaB2C1Page';
import CookieBanner from '../../../components/CookieBanner';
import { generateFAQSchema } from '../../../utils/schemaData';

const schemas = [
  articleSchema,
  ...(faqItems?.length > 0 ? [generateFAQSchema(faqItems)] : []),
];
---

<BaseLayout
  title="Diferencia entre B2 y C1 de Inglés: ¿Cuál Necesitas Realmente? [2026]"
  description="¿Cuál es la diferencia real entre B2 y C1 de inglés? Comparamos gramática, vocabulario, exámenes, salidas laborales y te ayudamos a decidir cuál necesitas."
  fullTitle={true}
  canonical="/blog/diferencia-b2-c1"
  ogType="article"
  schemas={schemas}
>
  <DiferenciaB2C1Page client:idle />
  <CookieBanner client:idle />
</BaseLayout>
