---
import BaseLayout from '../../layouts/BaseLayout.astro';
import C1AdvancedCaducaPage, { articleSchema, faqItems } from '../../../pages/blog/C1AdvancedCaducaPage';
import CookieBanner from '../../../components/CookieBanner';
import { generateFAQSchema } from '../../../utils/schemaData';

const schemas = [
  articleSchema,
  ...(faqItems?.length > 0 ? [generateFAQSchema(faqItems)] : []),
];
---

<BaseLayout
  title="¿El C1 Advanced de Cambridge Caduca? Validez Oficial [2026]"
  description="¿Caduca el certificado C1 Advanced de Cambridge? Respuesta oficial: NO caduca, pero algunas instituciones piden certificados recientes. Te explicamos cuándo y dónde."
  fullTitle={true}
  canonical="/blog/c1-advanced-caduca"
  ogType="article"
  schemas={schemas}
>
  <C1AdvancedCaducaPage client:idle />
  <CookieBanner client:idle />
</BaseLayout>
