---
import BaseLayout from '../../layouts/BaseLayout.astro';
import GreatLittlePeopleMetodologiaPage, { articleSchema, faqItems } from '../../../pages/blog/GreatLittlePeopleMetodologiaPage';
import CookieBanner from '../../../components/CookieBanner';
import { generateFAQSchema } from '../../../utils/schemaData';

const schemas = [
  articleSchema,
  ...(faqItems?.length > 0 ? [generateFAQSchema(faqItems)] : []),
];
---

<BaseLayout
  title="Great Little People Metodología"
  description="Great Little People es el método de inglés para niños de 1-7 años basado en inmersión total, juego y tecnología. Descubre cómo funciona y sus resultados."
  canonical="/blog/great-little-people-metodologia"
  ogType="article"
  schemas={schemas}
>
  <GreatLittlePeopleMetodologiaPage client:load />
  <CookieBanner client:idle />
</BaseLayout>
