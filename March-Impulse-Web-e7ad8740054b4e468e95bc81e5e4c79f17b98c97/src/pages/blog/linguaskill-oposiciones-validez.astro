---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LinguaskillOposicionesValidezPage, { articleSchema, faqItems } from '../../../pages/blog/LinguaskillOposicionesValidezPage';
import CookieBanner from '../../../components/CookieBanner';
import { generateFAQSchema } from '../../../utils/schemaData';

const schemas = [
  articleSchema,
  ...(faqItems?.length > 0 ? [generateFAQSchema(faqItems)] : []),
];
---

<BaseLayout
  title="Linguaskill para Oposiciones"
  description="Linguaskill es aceptado en oposiciones públicas en España con reconocimiento creciente. Descubre qué convocatorias lo aceptan y requisitos de nivel."
  canonical="/blog/linguaskill-oposiciones-validez"
  ogType="article"
  schemas={schemas}
>
  <LinguaskillOposicionesValidezPage client:idle />
  <CookieBanner client:idle />
</BaseLayout>
