---
import BaseLayout from '../../layouts/BaseLayout.astro';
import InglesColegioSuficientePage, { articleSchema, faqItems } from '../../../pages/blog/InglesColegioSuficientePage';
import CookieBanner from '../../../components/CookieBanner';
import { generateFAQSchema } from '../../../utils/schemaData';

const schemas = [
  articleSchema,
  ...(faqItems?.length > 0 ? [generateFAQSchema(faqItems)] : []),
];
---

<BaseLayout
  title="¿Inglés del Colegio Suficiente?"
  description="El inglés del colegio suele ser insuficiente: solo 2-3 horas semanales con grupos de 25 alumnos. Descubre por qué y cómo complementar la formación de tu hijo."
  canonical="/blog/ingles-colegio-suficiente"
  ogType="article"
  schemas={schemas}
>
  <InglesColegioSuficientePage client:idle />
  <CookieBanner client:idle />
</BaseLayout>
