---
import BaseLayout from '../../layouts/BaseLayout.astro';
import OpinionesLinguaskillPage, { articleSchema, faqs } from '../../../pages/blog/OpinionesLinguaskillPage';
import CookieBanner from '../../../components/CookieBanner';
import { generateFAQSchema } from '../../../utils/schemaData';

const schemas = [
  articleSchema,
  ...(faqs?.length > 0 ? [generateFAQSchema(faqs)] : []),
];
---

<BaseLayout
  title="Opiniones Linguaskill"
  description="Opiniones reales sobre Linguaskill: 87% usuarios satisfechos. Experiencias con formato adaptativo, modalidad online, corrección automatizada, resultados en 48h y comparativa con otros exámenes."
  canonical="/blog/opiniones-linguaskill"
  ogType="article"
  schemas={schemas}
>
  <OpinionesLinguaskillPage client:load />
  <CookieBanner client:idle />
</BaseLayout>
