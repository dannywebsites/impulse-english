---
import BaseLayout from '../../layouts/BaseLayout.astro';
import B1UniversidadEspanaPage, { articleSchema, faqItems } from '../../../pages/blog/B1UniversidadEspanaPage';
import CookieBanner from '../../../components/CookieBanner';
import { generateFAQSchema } from '../../../utils/schemaData';

const schemas = [
  articleSchema,
  ...(faqItems?.length > 0 ? [generateFAQSchema(faqItems)] : []),
];
---

<BaseLayout
  title="¿Necesitas B1 para la Universidad en España? Requisitos por Comunidad [2026]"
  description="¿Es obligatorio el B1 para graduarte en la universidad en España? Requisitos actualizados por comunidad autónoma, qué certificados aceptan y cómo sacarlo rápido."
  fullTitle={true}
  canonical="/blog/b1-universidad-espana"
  ogType="article"
  schemas={schemas}
>
  <B1UniversidadEspanaPage client:idle />
  <CookieBanner client:idle />
</BaseLayout>
