---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PrecioCambridgeC1MadridPage, { articleSchema, faqs } from '../../../pages/blog/PrecioCambridgeC1MadridPage';
import CookieBanner from '../../../components/CookieBanner';
import { generateFAQSchema } from '../../../utils/schemaData';

const schemas = [
  articleSchema,
  ...(faqs?.length > 0 ? [generateFAQSchema(faqs)] : []),
];
---

<BaseLayout
  title="Precio Cambridge C1 Advanced Madrid 2025: 233€ | Costes, Descuentos y Registro Completo"
  description="Precio del examen Cambridge C1 Advanced en Madrid: 233€ (223,50€ con descuento universitario). Plazos de inscripción, formatos digital y papel, centros autorizados."
  canonical="/blog/precio-cambridge-c1-madrid"
  ogType="article"
  schemas={schemas}
>
  <PrecioCambridgeC1MadridPage client:load />
  <CookieBanner client:idle />
</BaseLayout>
