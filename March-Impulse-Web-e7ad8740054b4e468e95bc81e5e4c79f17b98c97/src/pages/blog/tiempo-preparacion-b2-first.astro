---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TiempoPreparacionB2FirstPage, { articleSchema, faqItems } from '../../../pages/blog/TiempoPreparacionB2FirstPage';
import CookieBanner from '../../../components/CookieBanner';
import { generateFAQSchema } from '../../../utils/schemaData';

const schemas = [
  articleSchema,
  ...(faqItems?.length > 0 ? [generateFAQSchema(faqItems)] : []),
];
---

<BaseLayout
  title="¿Cuánto Tiempo Se Necesita para Preparar el B2 First? Plan de Estudio [2026]"
  description="¿Cuántos meses necesitas para preparar el B2 First? Depende de tu nivel actual. Te damos plazos realistas, un plan de estudio y los recursos imprescindibles."
  fullTitle={true}
  canonical="/blog/tiempo-preparacion-b2-first"
  ogType="article"
  schemas={schemas}
>
  <TiempoPreparacionB2FirstPage client:idle />
  <CookieBanner client:idle />
</BaseLayout>
