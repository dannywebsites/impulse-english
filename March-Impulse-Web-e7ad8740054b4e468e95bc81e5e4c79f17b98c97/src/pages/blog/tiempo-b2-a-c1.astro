---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TiempoB2AC1Page, { articleSchema, faqItems } from '../../../pages/blog/TiempoB2AC1Page';
import CookieBanner from '../../../components/CookieBanner';
import { generateFAQSchema } from '../../../utils/schemaData';

const schemas = [
  articleSchema,
  ...(faqItems?.length > 0 ? [generateFAQSchema(faqItems)] : []),
];
---

<BaseLayout
  title="¿Cuánto Tiempo Se Tarda en Pasar de B2 a C1? Plan Realista [2026]"
  description="Pasar de B2 a C1 lleva entre 6 y 12 meses según tu dedicación. Te damos un plan realista con horas de estudio, recursos y plazos para conseguir el C1 Advanced."
  fullTitle={true}
  canonical="/blog/tiempo-b2-a-c1"
  ogType="article"
  schemas={schemas}
>
  <TiempoB2AC1Page client:idle />
  <CookieBanner client:idle />
</BaseLayout>
