---
import BaseLayout from '../../layouts/BaseLayout.astro';
import NotaAprobarB2FirstPage, { articleSchema, faqItems } from '../../../pages/blog/NotaAprobarB2FirstPage';
import CookieBanner from '../../../components/CookieBanner';
import { generateFAQSchema } from '../../../utils/schemaData';

const schemas = [
  articleSchema,
  ...(faqItems?.length > 0 ? [generateFAQSchema(faqItems)] : []),
];
---

<BaseLayout
  title="Nota para Aprobar B2 First: Puntuación Mínima y Grades 2026"
  description="Para aprobar el B2 First necesitas 160 puntos en la Cambridge English Scale. Conoce las calificaciones Grade A, B y C, y cómo se evalúa cada parte."
  canonical="/blog/nota-aprobar-b2-first"
  ogType="article"
  schemas={schemas}
>
  <NotaAprobarB2FirstPage client:load />
  <CookieBanner client:idle />
</BaseLayout>
