---
import BaseLayout from '../../layouts/BaseLayout.astro';
import NotaAprobarB2FirstPage, { articleSchema, faqItems } from '../../../pages/blog/NotaAprobarB2FirstPage';
import CookieBanner from '../../../components/CookieBanner';
import { generateFAQSchema } from '../../../utils/schemaData';

const schemas = [
  articleSchema,
  ...(faqItems?.length > 0 ? [generateFAQSchema(faqItems)] : []),
];
---

<BaseLayout
  title="Nota para Aprobar el B2 First de Cambridge — Puntuación Mínima [2026]"
  description="¿Cuántos puntos necesitas para aprobar el B2 First? Nota mínima (160), escala de puntuación, qué pasa si sacas menos y cómo subir tu nota. Guía actualizada."
  fullTitle={true}
  canonical="/blog/nota-aprobar-b2-first"
  ogType="article"
  schemas={schemas}
>
  <NotaAprobarB2FirstPage client:idle />
  <CookieBanner client:idle />
</BaseLayout>
