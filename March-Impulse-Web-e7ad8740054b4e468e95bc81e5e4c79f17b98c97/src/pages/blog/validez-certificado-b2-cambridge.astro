---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ValidezCertificadoB2CambridgePage, { articleSchema, faqItems } from '../../../pages/blog/ValidezCertificadoB2CambridgePage';
import CookieBanner from '../../../components/CookieBanner';
import { generateFAQSchema } from '../../../utils/schemaData';

const schemas = [
  articleSchema,
  ...(faqItems?.length > 0 ? [generateFAQSchema(faqItems)] : []),
];
---

<BaseLayout
  title="¿Cuánto Dura el B2 de Cambridge? Validez y Caducidad [2026]"
  description="¿El certificado B2 First de Cambridge caduca? Te explicamos la validez oficial, qué instituciones lo aceptan sin límite y cuándo sí te pueden pedir renovarlo."
  fullTitle={true}
  canonical="/blog/validez-certificado-b2-cambridge"
  ogType="article"
  schemas={schemas}
>
  <ValidezCertificadoB2CambridgePage client:idle />
  <CookieBanner client:idle />
</BaseLayout>
