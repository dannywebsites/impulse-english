---
import BaseLayout from '../../layouts/BaseLayout.astro';
import InglesEntrevistasTrabajoPage, { articleSchema, faqItems } from '../../../pages/blog/InglesEntrevistasTrabajoPage';
import CookieBanner from '../../../components/CookieBanner';
import { generateFAQSchema } from '../../../utils/schemaData';

const schemas = [
  articleSchema,
  ...(faqItems?.length > 0 ? [generateFAQSchema(faqItems)] : []),
];
---

<BaseLayout
  title="Inglés Entrevistas de Trabajo"
  description="Prepara tu entrevista de trabajo en inglés: frases clave, preguntas frecuentes, vocabulario específico y técnicas de confianza. Guía práctica."
  canonical="/blog/ingles-entrevistas-trabajo"
  ogType="article"
  schemas={schemas}
>
  <InglesEntrevistasTrabajoPage client:idle />
  <CookieBanner client:idle />
</BaseLayout>
