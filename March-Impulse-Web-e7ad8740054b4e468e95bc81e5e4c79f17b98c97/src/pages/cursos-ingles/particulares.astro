---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ParticularesPage, { courseSchema, faqs } from '../../../pages/cursos/ParticularsPage';
import CookieBanner from '../../../components/CookieBanner';
import { generateFAQSchema } from '../../../utils/schemaData';
import { getImage } from 'astro:assets';
import { astroHeroImages } from '../../../utils/images-astro';

const heroImg = await getImage({
  src: astroHeroImages.danielHelping,
  format: 'webp',
  width: 1920,
  quality: 80,
});

const schemas = [
  courseSchema,
  ...(faqs?.length > 0 ? [generateFAQSchema(faqs)] : []),
];
---

<BaseLayout
  title="Clases Particulares Inglés"
  description="Clases particulares de inglés 1:1 en La Vaguada / Barrio del Pilar. 100% personalizadas, horarios flexibles, online o presencial. Preparación Cambridge y centro oficial Linguaskill."
  keywords="clases particulares inglés la vaguada, profesor particular inglés barrio del pilar, clases privadas inglés madrid"
  canonical="/cursos-ingles/particulares"
  schemas={schemas}
>
  <ParticularesPage heroImageSrc={heroImg.src} client:idle />
  <CookieBanner client:idle />
</BaseLayout>
