---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CursosOverviewPage, { faqs } from '../../../pages/cursos/CursosOverviewPage';
import CookieBanner from '../../../components/CookieBanner';
import { generateFAQSchema } from '../../../utils/schemaData';

const schemas = faqs?.length > 0 ? [generateFAQSchema(faqs)] : [];
---

<BaseLayout
  title="Cursos de Inglés en Madrid Norte"
  description="Cursos de inglés para todas las edades en Madrid Norte. Infantil, primaria, secundaria, adultos y clases particulares. Centro Cambridge oficial, grupos reducidos."
  keywords="cursos inglés madrid, clases inglés madrid norte, academia inglés cursos, inglés niños madrid, inglés adultos madrid"
  canonical="/cursos-ingles"
  schemas={schemas}
>
  <CursosOverviewPage client:idle />
  <CookieBanner client:idle />
</BaseLayout>
