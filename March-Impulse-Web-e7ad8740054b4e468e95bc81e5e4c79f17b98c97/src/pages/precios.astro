---
import BaseLayout from '../layouts/BaseLayout.astro';
import PreciosPage, { faqs } from '../../pages/PreciosPage';
import CookieBanner from '../../components/CookieBanner';
import { generateFAQSchema } from '../../utils/schemaData';
import { NAP } from '../../utils/napData';

const schemas = faqs?.length > 0 ? [generateFAQSchema(faqs)] : [];
---

<BaseLayout
  title="Precios y Tarifas"
  description={`Precios de clases de inglés en ${NAP.name} ${NAP.city}. Desde 64€/mes. Sin matrícula. Grupos reducidos, todas las edades, centro Cambridge oficial.`}
  keywords="precios academia inglés madrid, tarifas clases inglés, precio inglés madrid norte, cuánto cuesta academia inglés"
  canonical="/precios"
  schemas={schemas}
>
  <PreciosPage client:idle />
  <CookieBanner client:idle />
</BaseLayout>
