---
import BaseLayout from '../layouts/BaseLayout.astro';
import BarrioDelPilarPage, { locationMeta, localFaqs } from '../../pages/ubicaciones/BarrioDelPilarPage';
import CookieBanner from '../../components/CookieBanner';
import { generateLocationPageSchema, generateFAQSchema, generateBreadcrumbSchema } from '../../utils/schemaData';

const locationSchema = generateLocationPageSchema(locationMeta);
const locationItems = locationSchema["@graph"] || [locationSchema];
const breadcrumb = generateBreadcrumbSchema([
  { name: 'Inicio', url: 'https://impulse-english.es/' },
  { name: 'Ubicaciones', url: 'https://impulse-english.es/academias-ingles-madrid/por-barrios/' },
  { name: locationMeta.locationName, url: `${locationMeta.pageUrl}/` },
]);
const schemas = [...locationItems, breadcrumb, ...(localFaqs?.length > 0 ? [generateFAQSchema(localFaqs)] : [])];
---

<BaseLayout
  title="Clases de Inglés en Barrio del Pilar | Impulse"
  description="Clases y cursos de inglés en Barrio del Pilar, junto a La Vaguada. Centro oficial Cambridge, grupos reducidos y 100% de aprobados. Reserva tu prueba gratis."
  keywords="clases inglés barrio del pilar, cursos inglés barrio del pilar, inglés niños barrio del pilar, inglés adultos barrio del pilar, cambridge barrio del pilar"
  canonical="/academia-ingles-barrio-del-pilar"
  fullTitle={true}
  schemas={schemas}
>
  <BarrioDelPilarPage client:idle />
  <CookieBanner client:idle />
</BaseLayout>
