---
import BaseLayout from '../layouts/BaseLayout.astro';
import CuatroTorresPage, { locationMeta, localFaqs } from '../../pages/ubicaciones/CuatroTorresPage';
import CookieBanner from '../../components/CookieBanner';
import { generateLocationPageSchema, generateFAQSchema } from '../../utils/schemaData';

const locationSchema = generateLocationPageSchema(locationMeta);
const locationItems = locationSchema["@graph"] || [locationSchema];
const schemas = [...locationItems, ...(localFaqs?.length > 0 ? [generateFAQSchema(localFaqs)] : [])];
---

<BaseLayout
  title="Academia de Inglés en Cuatro Torres"
  description="Academia de inglés cerca de Cuatro Torres Business Area Madrid. Centro preparador Cambridge oficial. Horarios flexibles para profesionales. Grupos reducidos."
  keywords="academia inglés cuatro torres, clases inglés ctba, cursos inglés cuatro torres madrid, cambridge cuatro torres, aprender inglés profesionales madrid"
  canonical="/academia-ingles-cuatro-torres"
  schemas={schemas}
>
  <CuatroTorresPage client:load />
  <CookieBanner client:idle />
</BaseLayout>
