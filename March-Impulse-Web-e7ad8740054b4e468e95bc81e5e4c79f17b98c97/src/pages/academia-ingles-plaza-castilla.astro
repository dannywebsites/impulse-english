---
import BaseLayout from '../layouts/BaseLayout.astro';
import PlazaCastillaPage, { locationMeta, localFaqs } from '../../pages/ubicaciones/PlazaCastillaPage';
import CookieBanner from '../../components/CookieBanner';
import { generateLocationPageSchema, generateFAQSchema, generateBreadcrumbSchema } from '../../utils/schemaData';

const locationSchema = generateLocationPageSchema(locationMeta);
const locationItems = locationSchema["@graph"] || [locationSchema];
const breadcrumb = generateBreadcrumbSchema([
  { name: 'Inicio', url: 'https://impulse-english.es/' },
  { name: 'Ubicaciones', url: 'https://impulse-english.es/academias-ingles-madrid/por-barrios/' },
  { name: locationMeta.locationName, url: `${locationMeta.pageUrl}/` },
]);
const schemas = [...locationItems, breadcrumb, ...(localFaqs?.length > 0 ? [generateFAQSchema(localFaqs)] : [])];
---

<BaseLayout
  title="Academia Inglés Plaza Castilla"
  description="Academia de inglés cerca de Plaza Castilla Madrid. Centro preparador Cambridge oficial con 100% aprobados. A 15 min en Metro Línea 9. Grupos reducidos."
  keywords="academia inglés plaza castilla, clases inglés plaza castilla, cursos inglés plaza castilla madrid, cambridge plaza castilla, aprender inglés plaza castilla"
  canonical="/academia-ingles-plaza-castilla"
  schemas={schemas}
>
  <PlazaCastillaPage client:idle />
  <CookieBanner client:idle />
</BaseLayout>
