---
import BaseLayout from '../layouts/BaseLayout.astro';
import GraciasPage from '../../pages/GraciasPage';
import CookieBanner from '../../components/CookieBanner';
import { getImage } from 'astro:assets';
import { astroHeroImages } from '../../utils/images-astro';

const heroImg = await getImage({
  src: astroHeroImages.jpWithStudents,
  format: 'webp',
  width: 1920,
  quality: 80,
});
---

<BaseLayout
  title="Gracias"
  description="Tu solicitud ha sido recibida. Te contactaremos en menos de 24 horas."
  canonical="/gracias"
  noindex={true}
>
  <GraciasPage heroImageSrc={heroImg.src} client:idle />
  <CookieBanner client:idle />
</BaseLayout>
