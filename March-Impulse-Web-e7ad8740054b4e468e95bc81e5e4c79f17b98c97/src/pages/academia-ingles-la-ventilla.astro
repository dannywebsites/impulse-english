---
import BaseLayout from '../layouts/BaseLayout.astro';
import LaVentillaPage, { locationMeta, localFaqs } from '../../pages/ubicaciones/LaVentillaPage';
import CookieBanner from '../../components/CookieBanner';
import { generateLocationPageSchema, generateFAQSchema } from '../../utils/schemaData';

const locationSchema = generateLocationPageSchema(locationMeta);
const locationItems = locationSchema["@graph"] || [locationSchema];
const schemas = [...locationItems, ...(localFaqs?.length > 0 ? [generateFAQSchema(localFaqs)] : [])];
---

<BaseLayout
  title="Academia Inglés La Ventilla"
  description="Academia de inglés cerca de La Ventilla Madrid. Centro preparador Cambridge oficial con 100% aprobados. A 15 min de La Ventilla. Grupos reducidos máx 10 alumnos."
  keywords="academia inglés la ventilla, clases inglés la ventilla, cursos inglés la ventilla madrid, cambridge la ventilla, aprender inglés la ventilla"
  canonical="/academia-ingles-la-ventilla"
  schemas={schemas}
  skipGlobalAggregateRating={true}
>
  <LaVentillaPage client:load />
  <CookieBanner client:idle />
</BaseLayout>
