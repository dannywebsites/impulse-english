---
import BaseLayout from '../layouts/BaseLayout.astro';
import MirasierraPage, { locationMeta, localFaqs } from '../../pages/ubicaciones/MirasierraPage';
import CookieBanner from '../../components/CookieBanner';
import { generateLocationPageSchema, generateFAQSchema, generateBreadcrumbSchema } from '../../utils/schemaData';

const locationSchema = generateLocationPageSchema(locationMeta);
const locationItems = locationSchema["@graph"] || [locationSchema];
const breadcrumb = generateBreadcrumbSchema([
  { name: 'Inicio', url: 'https://impulse-english.es/' },
  { name: 'Ubicaciones', url: 'https://impulse-english.es/academias-ingles-madrid/por-barrios/' },
  { name: locationMeta.locationName, url: `${locationMeta.pageUrl}/` },
]);
const schemas = [...locationItems, breadcrumb, ...(localFaqs?.length > 0 ? [generateFAQSchema(localFaqs)] : [])];
---

<BaseLayout
  title="Academia Inglés Mirasierra"
  description="Academia de inglés cerca de Mirasierra Madrid. Centro preparador Cambridge oficial con 100% aprobados. A 4 min en Metro Línea 9. Grupos reducidos, todas las edades."
  keywords="academia inglés mirasierra, clases inglés mirasierra, cursos inglés mirasierra madrid, cambridge mirasierra, aprender inglés mirasierra"
  canonical="/academia-ingles-mirasierra"
  schemas={schemas}
>
  <MirasierraPage client:idle />
  <CookieBanner client:idle />
</BaseLayout>
