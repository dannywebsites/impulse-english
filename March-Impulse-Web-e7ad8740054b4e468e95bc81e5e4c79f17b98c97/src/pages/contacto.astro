---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactoPage from '../../pages/ContactoPage';
import CookieBanner from '../../components/CookieBanner';
import { getImage } from 'astro:assets';
import { astroHeroImages } from '../../utils/images-astro';
import { NAP } from '../../utils/napData';

const heroImg = await getImage({
  src: astroHeroImages.outsideAcademy,
  format: 'webp',
  width: 1920,
  quality: 80,
});
---

<BaseLayout
  title="Contacto"
  description={`Contacta con ${NAP.name}. ${NAP.streetAddress}, La Vaguada, ${NAP.city}. Tel: 604 910 611. Prueba de nivel gratuita. Metro Barrio del Pilar.`}
  keywords={`contacto academia inglés madrid, dirección ${NAP.shortName.toLowerCase()}, teléfono academia inglés la vaguada, horarios academia inglés`}
  canonical="/contacto"
>
  <ContactoPage heroImageSrc={heroImg.src} client:load />
  <CookieBanner client:idle />
</BaseLayout>
