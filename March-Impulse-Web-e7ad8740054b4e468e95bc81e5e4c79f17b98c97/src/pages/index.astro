---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar';
import Hero from '../../components/Hero';
import NewsOverlay from '../../components/NewsOverlay';
import WelcomeSection from '../../components/WelcomeSection';
import TeamSection from '../../components/TeamSection';
import CoursesSection from '../../components/CoursesSection';
import MetodoSection from '../../components/MetodoSection';
import PartnersSection from '../../components/PartnersSection';
import TestimonialsSection from '../../components/TestimonialsSection';
import ContactSection from '../../components/ContactSection';
import VideoCTA from '../../components/VideoCTA';
import Newsletter from '../../components/Newsletter';
import LocationsSection from '../../components/LocationsSection';
import Footer from '../../components/Footer';
import CookieBanner from '../../components/CookieBanner';
---

<BaseLayout
  title="Academia de Inglés La Vaguada y Barrio del Pilar | Impulse"
  description="Academia de inglés en La Vaguada y Barrio del Pilar, Madrid. Centro oficial Cambridge, profesores nativos y 100% aprobados. Reserva tu clase de prueba gratis."
  keywords="academia inglés barrio del pilar, academia inglés la vaguada, cambridge madrid, cursos inglés niños, clases inglés adultos, profesores nativos madrid"
  canonical="/"
  fullTitle={true}
>
  <!-- Hero Wrapper: Full Screen 100dvh -->
  <div class="relative w-full h-[100dvh] overflow-hidden bg-accent-blue">
    {/* DESKTOP BACKGROUND: static poster. The Vimeo hero video (id 1143999306)
        returned HTTP 401 (embed not authorized for this domain) and rendered a
        Vimeo error in the hero. Falling back to the poster image. To restore the
        video, re-add an iframe-injection script here once the video's Vimeo
        privacy/domain settings allow impulse-english.es. */}
    <div class="hidden xl:block absolute inset-0 z-0 pointer-events-none">
      <img
        src="/images/academy/hero-poster.jpg"
        alt="Impulse English Academy, La Vaguada, Barrio del Pilar"
        class="absolute inset-0 w-full h-full object-cover"
        loading="eager"
        fetchpriority="high"
      />
      <div class="absolute inset-0 bg-black/40 z-10"></div>
    </div>

    <!-- MOBILE/TABLET BACKGROUND: Optimized Image Fallback -->
    <div class="xl:hidden absolute inset-0 z-0">
      <div class="absolute inset-0 bg-black/30 z-10"></div>
      <picture>
        <source
          media="(max-width: 640px)"
          srcset="/images/optimized/hero-mobile-estudiantes-primaria.webp"
          type="image/webp"
        />
        <source
          media="(max-width: 640px)"
          srcset="/images/optimized/hero-mobile-estudiantes-primaria.jpg"
          type="image/jpeg"
        />
        <source
          srcset="/images/optimized/hero-tablet-estudiantes-primaria.webp"
          type="image/webp"
        />
        <source
          srcset="/images/optimized/hero-tablet-estudiantes-primaria.jpg"
          type="image/jpeg"
        />
        <img
          src="/images/optimized/hero-tablet-estudiantes-primaria.jpg"
          alt="Estudiantes de primaria sonriendo en clase de inglés - Impulse English Academy"
          class="absolute inset-0 w-full h-full object-cover"
          width="640"
          height="960"
          loading="eager"
          fetchpriority="high"
        />
      </picture>
    </div>

    <!-- Navbar -->
    <Navbar client:load currentPath="/" />

    <!-- Hero Content Layer -->
    <div class="relative z-[25] w-full h-full flex flex-col justify-center pointer-events-none">
      <Hero />
    </div>

    <!-- News Overlay (single render; responsive desktop grid + mobile sheet handled inside the component) -->
    <div class="absolute bottom-0 left-0 right-0 z-20 xl:translate-y-12 pointer-events-auto">
      <NewsOverlay />
    </div>
  </div>

  <WelcomeSection />
  <TeamSection />
  <CoursesSection client:visible />
  <MetodoSection />
  <PartnersSection />
  <TestimonialsSection client:visible />
  <VideoCTA />
  <LocationsSection />
  <ContactSection client:visible />
  <Newsletter client:visible />
  <Footer />
  <CookieBanner client:idle />
</BaseLayout>
