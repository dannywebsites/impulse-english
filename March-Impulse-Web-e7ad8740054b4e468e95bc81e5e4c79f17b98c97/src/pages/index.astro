---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar';
import Hero from '../../components/Hero';
import NewsOverlay from '../../components/NewsOverlay';
import WelcomeSection from '../../components/WelcomeSection';
import TeamSection from '../../components/TeamSection';
import CoursesSection from '../../components/CoursesSection';
import MetodoSection from '../../components/MetodoSection';
import PartnersSection from '../../components/PartnersSection';
import TestimonialsSection from '../../components/TestimonialsSection';
import ContactSection from '../../components/ContactSection';
import VideoCTA from '../../components/VideoCTA';
import Newsletter from '../../components/Newsletter';
import LocationsSection from '../../components/LocationsSection';
import Footer from '../../components/Footer';
import CookieBanner from '../../components/CookieBanner';
import { generateVideoObjectSchema } from '../../utils/schemaData';

// Self-hosted academy video, surfaced through the VideoCTA dialog. Marked up so the
// clip is eligible for video results — a background loop on its own earns nothing.
const videoSchema = generateVideoObjectSchema({
  name: 'Impulse English Academy en La Vaguada y Barrio del Pilar',
  description: 'Un recorrido por Impulse English Academy en La Vaguada, Barrio del Pilar: la entrada del centro y las clases de inglés de primaria y secundaria con nuestros profesores.',
  contentUrl: '/media/impulse-academia-la-vaguada.v1.mp4',
  thumbnailUrl: '/media/hero-poster.v1.jpg',
  uploadDate: '2025-12-05',
  duration: 'PT13S',
});
---

<BaseLayout
  title="Academia de Inglés La Vaguada y Barrio del Pilar | Impulse"
  description="Academia de inglés en La Vaguada y Barrio del Pilar, Madrid. Centro oficial Cambridge, profesores nativos y 100% aprobados. Reserva tu clase de prueba gratis."
  keywords="academia inglés barrio del pilar, academia inglés la vaguada, cambridge madrid, cursos inglés niños, clases inglés adultos, profesores nativos madrid"
  canonical="/"
  fullTitle={true}
  schemas={[videoSchema]}
>
  {/* Hero Wrapper. Whole-shot doctrine: ONE landscape edit, two presentations.
      Mobile/tablet = full-width 16:9 band showing the entire scene (never a crop of a
      wide shot, which always reads "zoomed"), with the copy on the solid blue panel
      below it. Desktop (xl+) = the same edit as a full-bleed 100dvh cover with the copy
      overlaid. The mobile top padding clears the fixed transparent navbar so the band is
      never covered by the logo. */}
  <div class="relative w-full bg-accent-blue flex flex-col pt-[150px] xl:pt-0 xl:block xl:h-[100dvh] xl:overflow-hidden">
    <video
      id="hero-video"
      autoplay
      muted
      loop
      playsinline
      preload="metadata"
      poster="/media/hero-poster.v1.jpg"
      aria-hidden="true"
      disablepictureinpicture
      class="relative z-0 w-full aspect-video object-cover bg-accent-blue select-none pointer-events-none motion-reduce:hidden xl:absolute xl:inset-0 xl:h-full xl:w-full xl:aspect-auto"
    >
      {/* Mobile source FIRST: the browser takes the first <source> whose media matches. */}
      <source src="/media/hero-landscape-mobile.v1.mp4" type="video/mp4" media="(max-width: 1279px)" />
      <source src="/media/hero-1080.v1.mp4" type="video/mp4" />
    </video>

    {/* Blocked-autoplay / reduced-motion fallback: the identical poster, same two presentations. */}
    <picture class="relative z-0 hidden w-full aspect-video select-none pointer-events-none motion-reduce:block xl:absolute xl:inset-0 xl:h-full xl:w-full xl:aspect-auto">
      <img
        src="/media/hero-poster.v1.jpg"
        alt="Fachada de Impulse English Academy en La Vaguada, Barrio del Pilar, con alumnos entrando a clase"
        class="w-full aspect-video object-cover xl:h-full xl:w-full xl:aspect-auto"
        fetchpriority="high"
      />
    </picture>

    {/* Legibility wash belongs to the DESKTOP overlay only. On mobile the copy sits on the
        solid blue panel and needs none. hidden xl:block is load-bearing. */}
    <div class="hidden xl:block absolute inset-0 bg-black/40 z-10 pointer-events-none"></div>

    <!-- Navbar -->
    <Navbar client:load currentPath="/" />

    <!-- Hero Content Layer -->
    <div class="relative z-[25] w-full pointer-events-none xl:absolute xl:inset-0 xl:h-full xl:flex xl:flex-col xl:justify-center">
      <Hero />
    </div>

    <!-- News Overlay (single render; responsive desktop grid + mobile sheet handled inside the component) -->
    <div class="relative z-20 mt-10 pointer-events-auto xl:absolute xl:bottom-0 xl:left-0 xl:right-0 xl:mt-0 xl:translate-y-12">
      <NewsOverlay />
    </div>
  </div>

  <script is:inline>
    // Hero video playback gate. Reduced-motion / data-saver: ABORT the download by
    // removing the <source> elements and reloading; the identical poster stays. CSS
    // display:none alone does NOT stop the fetch.
    (function () {
      var v = document.getElementById('hero-video');
      if (!v) return;
      var conn = navigator.connection || {};
      var slow = conn.saveData === true || /^(slow-2g|2g)$/.test(conn.effectiveType || '');
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches || slow) {
        var srcs = v.querySelectorAll('source');
        for (var i = 0; i < srcs.length; i++) srcs[i].remove();
        v.load();
        return;
      }
      // Rescue-swap: engines that ignore <source media> can pick the light mobile file on
      // a wide viewport. Put the 1080 file back on desktop.
      var fixDesktop = function () {
        if (!window.matchMedia('(min-width: 1280px)').matches) return;
        if (v.currentSrc && v.currentSrc.indexOf('hero-landscape-mobile') !== -1) {
          v.src = '/media/hero-1080.v1.mp4';
          v.load();
          v.play().catch(function () {});
        }
      };
      if (v.currentSrc) fixDesktop();
      else v.addEventListener('loadedmetadata', fixDesktop, { once: true });
      v.play().catch(function () {});
    })();
  </script>

  <WelcomeSection />
  <TeamSection />
  <CoursesSection client:visible />
  <MetodoSection />
  <PartnersSection />
  <TestimonialsSection client:visible />
  <VideoCTA client:visible />
  <LocationsSection />
  <ContactSection client:visible />
  <Newsletter client:visible />
  <Footer />
  <CookieBanner client:idle />
</BaseLayout>
