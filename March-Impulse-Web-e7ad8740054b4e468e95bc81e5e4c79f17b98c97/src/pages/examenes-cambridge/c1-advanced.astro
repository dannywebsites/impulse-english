---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ExamenCambridgeC1Page, { articleSchema, faqs } from '../../../pages/blog/ExamenCambridgeC1Page';
import CookieBanner from '../../../components/CookieBanner';
import { generateFAQSchema } from '../../../utils/schemaData';

const schemas = [
  articleSchema,
  ...(faqs?.length > 0 ? [generateFAQSchema(faqs)] : []),
];
---

<BaseLayout
  title="Examen C1 Advanced (CAE) Cambridge: Estructura, Precios y Preparación [2026]"
  description="Todo sobre el C1 Advanced de Cambridge: estructura del examen, precio en Madrid, fechas 2026, consejos de preparación y dónde presentarte. Centro preparador oficial."
  fullTitle={true}
  keywords="cambridge c1 advanced, examen c1 cambridge, c1 advanced puntuación, preparación c1, precio c1 cambridge, estructura c1 advanced"
  canonical="/examenes-cambridge/c1-advanced"
  ogType="article"
  schemas={schemas}
>
  <ExamenCambridgeC1Page client:idle />
  <CookieBanner client:idle />
</BaseLayout>
