---
/**
 * ArticleLayout.astro
 * Replaces the PAAArticlePage.tsx template pattern for blog/article pages.
 * Wraps BaseLayout with article-specific SEO (ogType=article, publishedTime, etc.)
 */
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  canonical: string;
  ogImage?: string;
  publishedTime?: string;
  modifiedTime?: string;
  schemas?: object[];
}

const {
  title,
  description,
  canonical,
  ogImage,
  publishedTime,
  modifiedTime,
  schemas = [],
} = Astro.props;
---

<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  ogType="article"
  ogImage={ogImage}
  publishedTime={publishedTime}
  modifiedTime={modifiedTime}
  schemas={schemas}
>
  <slot />
</BaseLayout>
