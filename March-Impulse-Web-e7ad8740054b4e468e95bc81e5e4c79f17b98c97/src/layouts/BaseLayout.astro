---
import '../index.css';
import { generateOrganizationSchema, generateWebSiteSchema } from '../../utils/schemaData';
import { buildPageTitle } from '../../utils/buildPageTitle';
import CoursePopup from '../../components/CoursePopup';

interface Props {
  title: string;
  description: string;
  keywords?: string;
  canonical?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  noindex?: boolean;
  publishedTime?: string;
  modifiedTime?: string;
  author?: string;
  fullTitle?: boolean;
  schemas?: object[];
}

const DEFAULT_OG_IMAGE = '/images/academy/logo-white-background.jpg';
const SITE_NAME = 'Impulse English Academy La Vaguada, Barrio del Pilar';
const BASE_URL = 'https://impulse-english.es';

const {
  title,
  description,
  keywords,
  canonical,
  ogImage = DEFAULT_OG_IMAGE,
  ogType = 'website',
  noindex = false,
  publishedTime,
  modifiedTime,
  author = 'Impulse English Academy',
  fullTitle = false,
  schemas = [],
} = Astro.props;

const pageTitle = fullTitle ? title : buildPageTitle(title);
// Ensure trailing slash on all canonical URLs for consistency with live site
const rawCanonical = canonical?.startsWith('http') ? canonical : `${BASE_URL}${canonical || '/'}`;
const canonicalUrl = rawCanonical.endsWith('/') ? rawCanonical : `${rawCanonical}/`;

// Auto-detect: if any page schema already carries aggregateRating, strip it
// from the global Organization schema to prevent Google's "Review has multiple
// aggregate ratings" error. This makes duplication structurally impossible.
let orgSchema: Record<string, unknown> = generateOrganizationSchema();
const pageHasAggregateRating = schemas.some(s =>
  (s as Record<string, unknown>).aggregateRating != null
);
if (pageHasAggregateRating) {
  const { aggregateRating: _, ...rest } = orgSchema;
  orgSchema = rest;
}
const globalSchemas = [orgSchema, generateWebSiteSchema()];
const allSchemas = [...globalSchemas, ...schemas];

// Build @graph structure (remove @context from individual items)
const schemaGraph = {
  "@context": "https://schema.org",
  "@graph": allSchemas.map(s => {
    const { "@context": _, ...rest } = s as { "@context"?: string; [key: string]: unknown };
    return rest;
  })
};
---

<!DOCTYPE html>
<html lang="es-ES" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#12477d" />

    <!-- Consent Mode - GDPR: default consent is DENIED; granted only after user accepts -->
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('consent', 'default', {
        'analytics_storage': 'denied',
        'ad_storage': 'denied',
        'wait_for_update': 500
      });
      /* Automated tracking tests visit with ?tt=test — tag their hits as
         internal traffic so the GA4 data filter excludes them from reports
         (still visible in Realtime/DebugView). Persisted per session so the
         flag survives in-site navigation. */
      try {
        if (location.search.indexOf('tt=test') !== -1) sessionStorage.setItem('imp_tt', 'test');
        if (sessionStorage.getItem('imp_tt') === 'test') gtag('set', { 'traffic_type': 'internal' });
      } catch (e) {}
      /* config MUST be queued here at parse time, not in the loader's onload:
         events fired before gtag.js loads (e.g. a first-tap WhatsApp click that
         itself triggers the deferred load) are only delivered if a config
         command precedes them in the dataLayer queue. */
      /* G-KNMS5YW69T is the ONLY data stream of GA4 property 503609664
         ("Impulse-English" — the property all reporting reads). The GTM
         container (GTM-TDC7CQDD) holds GA4 event tags for this same stream
         and already sends page_view — hence send_page_view: false here.
         G-WN5973VY1M (previously configured) is NOT a stream of that
         property; events sent to it never reached our reports. */
      gtag('js', new Date());
      gtag('config', 'G-KNMS5YW69T', { 'send_page_view': false });
      gtag('config', 'AW-11461982741');
    </script>

    <!-- Deferred GA4 + GTM: loads after 3.5s or first user interaction -->
    <script is:inline>
      (function(){
        var loaded = false;
        function load(){
          if(loaded) return; loaded = true;
          var g = document.createElement('script');
          g.src = 'https://www.googletagmanager.com/gtag/js?id=G-KNMS5YW69T';
          g.async = true;
          document.head.appendChild(g);
          (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
          new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
          j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
          'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
          })(window,document,'script','dataLayer','GTM-TDC7CQDD');
        }
        setTimeout(load, 3500);
        ['scroll','click','touchstart','keydown'].forEach(function(e){
          document.addEventListener(e, load, {once:true, passive:true});
        });
      })();
    </script>

    <!-- Contact-click tracking → GA4 (phone + WhatsApp). gtag() is defined above. -->
    <script is:inline>
      document.addEventListener('click', function (e) {
        var a = e.target && e.target.closest ? e.target.closest('a[href]') : null;
        if (!a) return;
        var href = a.getAttribute('href') || '';
        var hl = href.toLowerCase();
        /* send_to is REQUIRED: GTM also loads destination G-KNMS5YW69T on this
           page and claims it, so events without an explicit send_to are
           silently dropped instead of routed (verified live 2026-07-06). */
        if (hl.indexOf('wa.me') !== -1 || hl.indexOf('whatsapp.com') !== -1 || hl.indexOf('whatsapp:') !== -1) {
          gtag('event', 'whatsapp_click', { send_to: 'G-KNMS5YW69T', link_url: href, page_path: location.pathname });
        } else if (href.indexOf('tel:') === 0) {
          gtag('event', 'phone_click', { send_to: 'G-KNMS5YW69T', phone_number: href.replace('tel:', ''), page_path: location.pathname });
        } else if (hl.indexOf('mailto:') === 0) {
          gtag('event', 'email_click', { send_to: 'G-KNMS5YW69T', email_address: href.replace(/^mailto:/i, ''), page_path: location.pathname });
        }
      }, { passive: true });
    </script>

    <!-- SEO Meta Tags (server-rendered) -->
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow, max-image-preview:large'} />
    {keywords && <meta name="keywords" content={keywords} />}
    <meta name="author" content={author} />
    <meta name="publisher" content={SITE_NAME} />
    <meta name="geo.region" content="ES-MD" />
    <meta name="geo.placename" content="Madrid" />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:locale" content="es_ES" />
    <meta property="og:url" content={canonicalUrl} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:site" content="@ImpulseEnglish" />
    <meta name="twitter:creator" content="@ImpulseEnglish" />

    <!-- Article-specific tags -->
    {ogType === 'article' && publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {ogType === 'article' && modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
    {ogType === 'article' && <meta property="article:author" content={author} />}

    <!-- Favicons -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="192x192" href="/images/optimized/favicon-192x192.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/images/optimized/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/images/optimized/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/images/optimized/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <!-- Fonts (non-render-blocking) -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:wght@400;600;700&display=swap">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:wght@400;600;700&display=swap" media="print" onload="this.media='all'">
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:wght@400;600;700&display=swap"></noscript>

    <!-- Hero poster preload (homepage only). The hero video is self-hosted from /media/,
         so there are no third-party video origins left to preconnect to. The poster is
         what paints before playback, so it is the LCP candidate worth preloading. -->
    {Astro.url.pathname === '/' && (
      <link rel="preload" as="image" href="/media/hero-poster.v1.jpg" fetchpriority="high">
    )}

    <!-- Hero entrance animations -->
    <style>
      @keyframes heroFadeUp {
        from { opacity: 0; transform: translateY(28px); }
        to { opacity: 1; transform: translateY(0); }
      }
      @keyframes heroFadeIn {
        from { opacity: 0; }
        to { opacity: 1; }
      }
      .animate-hero-fade-up {
        opacity: 0;
        animation: heroFadeUp 0.9s cubic-bezier(0.22, 1, 0.36, 1) forwards;
      }
      .animate-hero-fade-in {
        opacity: 0;
        animation: heroFadeIn 1s ease-out forwards;
      }
      .animation-delay-100 { animation-delay: 0.1s; }
      .animation-delay-150 { animation-delay: 0.15s; }
      .animation-delay-200 { animation-delay: 0.2s; }
      .animation-delay-300 { animation-delay: 0.3s; }
      .animation-delay-400 { animation-delay: 0.4s; }

      /* Subtle grain texture for hero depth */
      .hero-grain {
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
        background-repeat: repeat;
        background-size: 128px 128px;
        pointer-events: none;
      }
    </style>

    <!-- JSON-LD Structured Data (server-rendered) -->
    <script is:inline type="application/ld+json" set:html={JSON.stringify(schemaGraph)} />
  </head>
  <body>
    <a href="#main" class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 focus:z-[100] focus:bg-white focus:text-accent-blue focus:px-4 focus:py-2 focus:rounded focus:shadow-lg focus:font-semibold">
      Saltar al contenido principal
    </a>
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-TDC7CQDD"
    height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->

    <main id="main" class="min-h-screen w-full bg-white flex flex-col font-sans selection:bg-accent-blue selection:text-white">
      <slot />
    </main>
    <!-- Time-on-page lead-capture popup (20s, page-level-aware) -->
    <CoursePopup client:idle />
    <script>
      const loadAnalytics = () => {
        import('@vercel/analytics').then(m => m.inject());
        import('@vercel/speed-insights').then(m => m.injectSpeedInsights());
      };
      if (typeof requestIdleCallback !== 'undefined') {
        requestIdleCallback(loadAnalytics);
      } else {
        setTimeout(loadAnalytics, 2000);
      }
    </script>
  </body>
</html>
